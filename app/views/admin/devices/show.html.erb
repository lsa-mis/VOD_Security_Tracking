<%= render "admin/shared/page_header", title: "Device ##{@resource.id}" %>
<div class="mb-4">
  <%= link_to "Edit in app", device_path(@resource), class: "rounded bg-sky-700 px-3 py-2 text-sm text-white" %>
  <%= link_to "Back", admin_devices_path, class: "rounded border px-3 py-2 text-sm ml-2" %>
</div>
<div class="rounded border border-slate-200 bg-white p-4 mb-6">
  <%= admin_attr_rows(@resource, %i[serial hostname mac building room owner department manufacturer model]) %>
</div>
<%= render "admin/shared/comments", resource: @resource %>
