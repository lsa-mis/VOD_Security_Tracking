<%= render "admin/shared/page_header", title: "DSA Exceptions", csv_path: admin_dpa_exceptions_path(format: :csv, scope: @current_scope) %>
<%= admin_scope_tabs(%i[active archived], @current_scope || :active) %>

<div class="overflow-x-auto rounded border border-slate-200 bg-white">
  <table class="min-w-full text-sm">
    <thead class="bg-slate-50 border-b">
      <tr>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Actions</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Status</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Incomplete</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">First Approval</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Third Party Product/Service</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Department</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Data Type</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Next Review</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Last Review</th>
        <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Archived at</th>
      </tr>
    </thead>
    <tbody>
      <% @resources.each do |resource| %>
        <tr class="border-b border-slate-100">
          <td class="px-3 py-2"><%= link_to "View", admin_dpa_exception_path(resource), class: "text-sky-700 hover:underline" %></td>
          <td class="px-3 py-2"><%= show_dpa_exception_status(resource) %></td>
          <td class="px-3 py-2"><%= resource.incomplete %></td>
          <td class="px-3 py-2"><%= resource.review_date_exception_first_approval_date %></td>
          <td class="px-3 py-2"><%= resource.third_party_product_service %></td>
          <td class="px-3 py-2"><%= show_department_name(resource) if resource.department %></td>
          <td class="px-3 py-2"><%= show_data_type_name(resource) %></td>
          <td class="px-3 py-2"><%= resource.exception_approval_date_exception_renewal_date_due %></td>
          <td class="px-3 py-2"><%= resource.review_date_exception_review_date %></td>
          <td class="px-3 py-2"><%= resource.deleted_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<%= render "admin/shared/pagination" %>
