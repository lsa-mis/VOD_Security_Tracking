<%= render "admin/shared/page_header", title: "Access Lookups ##{@resource.id}" %>
<div class="mb-4 flex gap-2">
  <%= link_to "Edit", [:edit, :admin, @resource], class: "rounded bg-sky-700 px-3 py-2 text-sm text-white" %>
  <%= link_to "Back", admin_access_lookups_path, class: "rounded border px-3 py-2 text-sm" %>
  <%= button_to "Delete", [:admin, @resource], method: :delete, form: { data: { turbo_confirm: "Delete?" }, class: "inline" }, class: "rounded bg-red-700 px-3 py-2 text-sm text-white" %>
</div>
<div class="rounded border border-slate-200 bg-white p-4 mb-6">
  <%= admin_attr_rows(@resource, [
    ["Ldap group", @resource.ldap_group],
    ["Vod table", @resource.vod_table],
    ["Vod action", @resource.vod_action],
  ]) %>
</div>
<%= render "admin/shared/comments", resource: @resource %>
