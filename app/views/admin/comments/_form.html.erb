<%= form_with model: [:admin, @resource], class: "max-w-xl rounded border border-slate-200 bg-white p-4" do |f| %>
  <% if @resource.errors.any? %>
    <div class="mb-3 text-sm text-red-700"><%= @resource.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="mb-3"><%= f.label :body, class: "block text-sm text-slate-600" %><%= f.text_area :body, rows: 4, class: "rounded border-slate-300 w-full" %></div>
  <div class="mb-3"><%= f.label :namespace, class: "block text-sm text-slate-600" %><%= f.text_field :namespace, class: "rounded border-slate-300 w-full" %></div>
  <div class="mb-3"><%= f.label :resource_type, class: "block text-sm text-slate-600" %><%= f.text_field :resource_type, class: "rounded border-slate-300 w-full" %></div>
  <div class="mb-3"><%= f.label :resource_id, class: "block text-sm text-slate-600" %><%= f.number_field :resource_id, class: "rounded border-slate-300 w-full" %></div>
  <div class="flex gap-2 mt-4">
    <%= f.submit class: "rounded bg-sky-700 px-3 py-2 text-sm text-white" %>
    <%= link_to "Cancel", admin_comments_path, class: "rounded border px-3 py-2 text-sm" %>
  </div>
<% end %>
