<%= render "admin/shared/page_header", title: "Comments", new_path: new_admin_comment_path, csv_path: admin_comments_path(format: :csv, q: params[:q]&.permit!.to_h) %>

<%= search_form_for @q, url: admin_comments_path, html: { class: "mb-4 flex flex-wrap gap-2 items-end" } do |f| %>
  <div><%= f.label :body_cont, "Body", class: "block text-xs text-slate-500" %><%= f.search_field :body_cont, class: "rounded border-slate-300 text-sm" %></div>
  <div><%= f.label :namespace_cont, "Namespace", class: "block text-xs text-slate-500" %><%= f.search_field :namespace_cont, class: "rounded border-slate-300 text-sm" %></div>
  <div><%= f.label :resource_type_cont, "Resource type", class: "block text-xs text-slate-500" %><%= f.search_field :resource_type_cont, class: "rounded border-slate-300 text-sm" %></div>
  <%= f.submit "Filter", class: "rounded bg-slate-700 px-3 py-2 text-sm text-white" %>
  <%= link_to "Clear", admin_comments_path, class: "text-sm text-sky-700" %>
<% end %>

<% content = capture do %>
  <div class="overflow-x-auto rounded border border-slate-200 bg-white">
    <table class="min-w-full text-sm">
      <thead class="bg-slate-50 border-b">
        <tr>
      <th class="px-3 py-2"></th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Actions</th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Body</th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Namespace</th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Resource type</th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Resource</th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Author type</th>
      <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">Created at</th>
        </tr>
      </thead>
      <tbody>
        <% @resources.each do |resource| %>
          <tr class="border-b border-slate-100 hover:bg-slate-50">
        <td class="px-3 py-2"><input type="checkbox" name="ids[]" value="<%= resource.id %>"></td>
        <td class="px-3 py-2 whitespace-nowrap">
              <%= render "admin/shared/table_actions", resource: resource %>
            </td>
        <td class="px-3 py-2"><%= resource.body %></td>
        <td class="px-3 py-2"><%= resource.namespace %></td>
        <td class="px-3 py-2"><%= resource.resource_type %></td>
        <td class="px-3 py-2"><%= resource.resource_id %></td>
        <td class="px-3 py-2"><%= resource.author_type %></td>
        <td class="px-3 py-2"><%= resource.created_at %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if true %>
  <%= render layout: "admin/shared/batch_form", locals: { batch_path: batch_destroy_admin_comments_path } do %>
    <%= content %>
  <% end %>
<% else %>
  <%= content %>
<% end %>

<%= render "admin/shared/pagination" %>
