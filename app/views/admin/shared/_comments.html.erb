<div class="mb-6 rounded border border-slate-200 bg-white p-4">
  <h2 class="text-sm font-semibold text-slate-700 mb-3">Comments</h2>
  <% comments = Comment.where(resource: resource).order(created_at: :desc) %>
  <ul class="space-y-3 mb-4">
    <% comments.each do |comment| %>
      <li class="border-b border-slate-100 pb-2">
        <p class="text-sm text-slate-800"><%= comment.body %></p>
        <p class="text-xs text-slate-500 mt-1">
          <%= comment.author.try(:username) || comment.author_type %> · <%= comment.created_at %>
        </p>
      </li>
    <% end %>
    <% if comments.empty? %>
      <li class="text-sm text-slate-500">No comments yet.</li>
    <% end %>
  </ul>

  <%= form_with model: Comment.new, url: admin_comments_path, class: "space-y-2" do |f| %>
    <%= f.hidden_field :resource_type, value: resource.class.name %>
    <%= f.hidden_field :resource_id, value: resource.id %>
    <%= f.hidden_field :namespace, value: "admin" %>
    <%= f.text_area :body, rows: 3, class: "w-full rounded border-slate-300 text-sm", placeholder: "Add a comment" %>
    <%= f.submit "Add Comment", class: "rounded bg-sky-700 px-3 py-1.5 text-sm text-white hover:bg-sky-800" %>
  <% end %>
</div>
