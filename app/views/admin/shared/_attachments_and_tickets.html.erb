<section class="mb-6 rounded border border-slate-200 bg-white p-4">
  <h2 class="text-sm font-semibold text-slate-700 mb-3">Attachments</h2>
  <% if resource.respond_to?(:attachments) && resource.attachments.attached? %>
    <ul class="text-sm space-y-1">
      <% resource.attachments.each do |item| %>
        <li><%= link_to item.filename, url_for(item), class: "text-sky-700 hover:underline" %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-500">No attachments.</p>
  <% end %>
</section>

<section class="mb-6 rounded border border-slate-200 bg-white p-4">
  <h2 class="text-sm font-semibold text-slate-700 mb-3">TDX Tickets</h2>
  <% if resource.respond_to?(:tdx_tickets) && resource.tdx_tickets.any? %>
    <ul class="text-sm space-y-1">
      <% resource.tdx_tickets.each do |item| %>
        <li><%= link_to item.ticket_link, item.ticket_link, class: "text-sky-700 hover:underline", target: "_blank" %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-500">No TDX tickets.</p>
  <% end %>
</section>
