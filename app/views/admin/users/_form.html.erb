<%= form_with model: [:admin, @resource], class: "max-w-xl rounded border border-slate-200 bg-white p-4" do |f| %>
  <% if @resource.errors.any? %>
    <div class="mb-3 text-sm text-red-700"><%= @resource.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="mb-3"><%= f.label :username, class: "block text-sm text-slate-600" %><%= f.text_field :username, class: "rounded border-slate-300 w-full" %></div>
  <div class="mb-3"><%= f.label :email, class: "block text-sm text-slate-600" %><%= f.text_field :email, class: "rounded border-slate-300 w-full" %></div>
  <div class="mb-3"><%= f.label :remember_created_at, class: "block text-sm text-slate-600" %><%= f.datetime_field :remember_created_at, class: "rounded border-slate-300 w-full" %></div>
  <div class="flex gap-2 mt-4">
    <%= f.submit class: "rounded bg-sky-700 px-3 py-2 text-sm text-white" %>
    <%= link_to "Cancel", admin_users_path, class: "rounded border px-3 py-2 text-sm" %>
  </div>
<% end %>
