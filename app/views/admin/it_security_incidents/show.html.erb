<%= render "admin/shared/page_header", title: "IT Security Incident ##{@resource.id}" %>
<div class="mb-4 flex gap-2">
  <% if @resource.deleted_at.present? %>
    <%= button_to "Unarchive record", unarchive_it_security_incident_path(@resource), method: :post, class: "rounded bg-amber-600 px-3 py-2 text-sm text-white" %>
  <% end %>
  <%= link_to "Back", admin_it_security_incidents_path, class: "rounded border px-3 py-2 text-sm" %>
</div>
<div class="rounded border border-slate-200 bg-white p-4 mb-6">
  <%= admin_attr_rows(@resource, [
    ["Status", show_it_security_incident_status(@resource)],
    ["Archived at", @resource.deleted_at],
    :incomplete, :title, :date, :people_involved, :equipment_involved,
    :remediation_steps, :estimated_financial_cost, :notes,
    ["Data Type", show_data_type_name(@resource)]
  ]) %>
</div>
<%= render "admin/shared/attachments_and_tickets", resource: @resource %>
<%= render "admin/shared/comments", resource: @resource %>
